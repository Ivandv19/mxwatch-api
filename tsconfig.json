{
	"compilerOptions": {
		// --- OPTIMIZACIONES ---
		"target": "ESNext", // JS moderno
		"module": "ESNext", // Soporta import/export nativo
		"moduleResolution": "Bundler", // Ideal para Bun/Vite

		// --- CALIDAD ---
		"strict": true, // Tipado fuerte
		"skipLibCheck": true, // Ignorar tipos de node_modules (compila más rápido)
		"lib": ["ESNext"],

		// --- VISTAS / HONO ---
		"jsx": "react-jsx", // Sintaxis similar a HTML/React
		"jsxImportSource": "hono/jsx" // Usa el JSX ultra rápido de Hono, no React
	}
}
